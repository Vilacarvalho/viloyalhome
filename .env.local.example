# Contato exigido pela política de uso do Nominatim (geocodificação reversa).
# Use um e-mail ou URL real do projeto em produção.
GEOCODER_CONTACT="viloyalhome (contato: seu-email@dominio.com)"

# ---------------------------------------------------------------------------
# Geoportal (cadastro + valor venal por coordenada) — opcional.
#
# Deixe em branco para desativar (o app mostra o link do portal de Cascavel
# como alternativa manual). Para ativar a consulta automática, aponte para a
# camada cadastral do município. Suporta dois tipos:
#
#   GEOPORTAL_KIND = arcgis  -> URL da CAMADA ArcGIS (…/MapServer/0 ou
#                               …/FeatureServer/0). O app chama /query por ponto.
#   GEOPORTAL_KIND = wms     -> URL base do WMS. Informe também GEOPORTAL_WMS_LAYERS.
#
# A URL exata de Cascavel precisa ser confirmada numa rede que alcance
# *.cascavel.pr.gov.br (o ambiente de desenvolvimento remoto bloqueia esse host).
# ---------------------------------------------------------------------------
GEOPORTAL_KIND=""
GEOPORTAL_URL=""
# SR do ponto enviado (padrão 4326 = lat/lon). O servidor reprojeta a camada.
GEOPORTAL_WKID="4326"

# Só para GEOPORTAL_KIND=wms:
GEOPORTAL_WMS_VERSION="1.3.0"
GEOPORTAL_WMS_LAYERS=""

# Opcional: sobrescreve o mapeamento de nomes de colunas do cadastro, em JSON.
# Ex.: {"valorVenal":["vl_venal_total"],"inscricao":["cod_cadastro"]}
GEOPORTAL_FIELDS=""
